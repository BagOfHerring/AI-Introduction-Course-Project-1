<mujoco model="panda scene with workbench">

  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6"  ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
        height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
        rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
        reflectance="0.2"/>
    <material name="table_wood" rgba="0.62 0.50 0.38 1" specular="0.10" shininess="0.08" reflectance="0.03"/>


    <mesh name="gear_mesh_1" file="gear.stl" scale="0.0018 0.0018 0.0018"/>
    <mesh name="gear_mesh_2" file="gear.stl" scale="0.0017 0.0017 0.0017"/>
    <mesh name="square_gear_mesh_1" file="square_gear.stl" scale="0.0015 0.0015 0.0015"/>
    <mesh name="square_gear_mesh_2" file="square_gear.stl" scale="0.0016 0.0016 0.0016"/>
    <mesh name="nut_mesh_1" file="nut.stl" scale="0.0019 0.0019 0.0019"/>
    <mesh name="nut_mesh_2" file="nut.stl" scale="0.0020 0.0020 0.0020"/>
    <mesh name="bearing_mesh_1" file="bearing.stl" scale="0.0015 0.0015 0.0015"/>
    <mesh name="bearing_mesh_2" file="bearing.stl" scale="0.0015 0.0015 0.0015"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Workbench -->
    <body name="table" pos="0.5 0 0.2">
            <geom type="box" size="0.4 0.6 0.2" material="table_wood"/>
      <!-- Quadrant Dividers -->
      <geom type="box" name="divider_x" pos="0 0 0.201" size="0.4 0.005 0.001" rgba="0 0 0 1" contype="0" conaffinity="0"/>
      <geom type="box" name="divider_y" pos="0 0 0.201" size="0.005 0.6 0.001" rgba="0 0 0 1" contype="0" conaffinity="0"/>
    </body>

    <!-- Camera -->
    <camera name="vision_cam" pos="0.5 0.0 1.4" fovy="45" xyaxes="0 -1 0 1 0 0"/>

    <!-- Randomized Parts (8 total: 4 types x 2 each) -->

    <body name="part_gear_1" pos="0.705 0.012 0.600" euler="0 0 -2.361846">
      <freejoint/>
      <geom type="mesh" mesh="gear_mesh_1" rgba="0.12 0.74 0.98 1" mass="0.077" friction="1 0.005 0.0001"/>
    </body>

    <body name="part_gear_2" pos="0.359 -0.173 0.600" euler="0 0 0.704284">
      <freejoint/>
      <geom type="mesh" mesh="gear_mesh_2" rgba="0.98 0.84 0.16 1" mass="0.107" friction="1 0.005 0.0001"/>
    </body>

    <body name="part_square_gear_1" pos="0.590 0.077 0.600" euler="0 0 -2.223258">
      <freejoint/>
      <geom type="mesh" mesh="square_gear_mesh_1" rgba="0.95 0.27 0.27 1" mass="0.156" friction="1 0.005 0.0001"/>
    </body>

    <body name="part_square_gear_2" pos="0.565 0.222 0.600" euler="0 0 -2.538285">
      <freejoint/>
      <geom type="mesh" mesh="square_gear_mesh_2" rgba="0.72 0.26 0.98 1" mass="0.196" friction="1 0.005 0.0001"/>
    </body>

    <body name="part_nut_1" pos="0.303 0.036 0.600" euler="0 0 1.071940">
      <freejoint/>
      <geom type="mesh" mesh="nut_mesh_1" rgba="0.18 0.82 0.43 1" mass="0.155" friction="1 0.005 0.0001"/>
    </body>

    <body name="part_nut_2" pos="0.259 0.356 0.600" euler="0 0 1.697242">
      <freejoint/>
      <geom type="mesh" mesh="nut_mesh_2" rgba="0.96 0.38 0.14 1" mass="0.191" friction="1 0.005 0.0001"/>
    </body>

    <body name="part_bearing_1" pos="0.405 -0.351 0.600" euler="0 0 3.135950">
      <freejoint/>
      <geom type="mesh" mesh="bearing_mesh_1" rgba="0.12 0.74 0.98 1" mass="0.116" friction="1 0.005 0.0001"/>
    </body>

    <body name="part_bearing_2" pos="0.708 -0.157 0.600" euler="0 0 -1.057709">
      <freejoint/>
      <geom type="mesh" mesh="bearing_mesh_2" rgba="0.98 0.84 0.16 1" mass="0.117" friction="1 0.005 0.0001"/>
    </body>

  </worldbody>
</mujoco>
